# PostgreSQL
DATABASE_URL=postgresql+asyncpg://isekai:isekai@localhost:5432/isekai

# Redis
REDIS_URL=redis://localhost:6379/0

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_WEBHOOK_SECRET=changeme_to_random_string

# LLM провайдеры
OPENAI_API_KEY=your_openrouter_or_openai_key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_LLM_PROVIDER=openai

# Image провайдеры (заполнить позже)
RUNWARE_API_KEY=
FAL_API_KEY=
DEFAULT_IMAGE_PROVIDER=runware

# Storage — MinIO для локальной разработки
# Для прода заменить на Cloudflare R2 (поменять только эти переменные, код менять не нужно)
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=storyweave-assets
STORAGE_PUBLIC_URL=http://localhost:9000/storyweave-assets


# Приложение
DEBUG=true
WEBHOOK_BASE_URL=https://yourdomain.com
